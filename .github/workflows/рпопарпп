name: Build APK
on: [push, workflow_dispatch]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Build APK
        uses: engineer144/love-actions@v1.4.1
        with:
          game_path: BombAll.love # ТВОЁ НАЗВАНИЕ ФАЙЛА
          bundle_id: com.kilfy.bomball # Твой ID
          game_name: "Bomb All" # Название игры

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: BombAll-APK
          path: "*.apk"
